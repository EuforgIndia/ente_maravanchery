<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Test</title>
    <style>
        body { font-family: Arial; padding: 20px; background: #0a0a0a; color: white; }
        button { padding: 15px; margin: 10px 0; width: 100%; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; }
        .wa { background: #25D366; color: white; }
        .status { background: #1a1a1a; padding: 10px; border-radius: 5px; font-family: monospace; margin-top: 20px; }
    </style>
</head>
<body>
    <h3>WhatsApp Test</h3>
    <button class="wa" onclick="sendWA()">Open WhatsApp (7594993481)</button>
    <div class="status" id="status">Click button</div>

    <script>
        function sendWA() {
            var cmd = 'wa:917594993481';
            document.getElementById('status').innerHTML = 'Sending: ' + cmd;
            
            if (window.Kodular) {
                window.Kodular.setWebViewString(cmd);
                document.getElementById('status').innerHTML += '<br>✅ Sent to Kodular';
            } else {
                document.getElementById('status').innerHTML += '<br>❌ Not in Kodular';
                window.open('https://wa.me/917594993481', '_blank');
            }
        }
    </script>
</body>
</html>
